;;; ============================================================
;;; Helper: interpolate control points to N entries
;;; ============================================================

(defun %interpolate-control-points (control-points n)
  "Interpolate CONTROL-POINTS (list of (R G B) lists) to N RGB entries.
Returns a list of N (R G B) lists."
  (let* ((ncp (length control-points))
         (cp (coerce control-points 'vector))
         (result nil))
    (dotimes (i n)
      (let* ((t-val (/ (float i 1.0d0) (float (1- n) 1.0d0)))
             (scaled (* t-val (1- ncp)))
             (idx (min (floor scaled) (- ncp 2)))
             (frac (- scaled idx))
             (c0 (aref cp idx))
             (c1 (aref cp (1+ idx))))
        (push (list (+ (first c0) (* frac (- (first c1) (first c0))))
                    (+ (second c0) (* frac (- (second c1) (second c0))))
                    (+ (third c0) (* frac (- (third c1) (third c0)))))
              result)))
    (nreverse result)))

;;; ============================================================
;;; Initialize all colormaps
;;; ============================================================

(defun %register-segment-cmap (name segment-data &key (n 256))
  "Create and register a LinearSegmentedColormap."
  (register-colormap
   (make-linear-segmented-colormap name segment-data :n n)
   :name name :force t))

(defun %register-from-list-cmap (name color-data &key (n 256))
  "Create and register a colormap from a list of RGB tuples.
COLOR-DATA is a list of (R G B) lists."
  (let ((colors (mapcar (lambda (rgb)
                          (vector (float (first rgb) 1.0d0)
                                  (float (second rgb) 1.0d0)
                                  (float (third rgb) 1.0d0)
                                  1.0d0))
                        color-data)))
    (register-colormap
     (linear-segmented-colormap-from-list name colors :n n)
     :name name :force t)))

(defun %register-listed-cmap (name color-data)
  "Create and register a ListedColormap from RGB data."
  (let ((colors (mapcar (lambda (rgb)
                          (vector (float (first rgb) 1.0d0)
                                  (float (second rgb) 1.0d0)
                                  (float (third rgb) 1.0d0)
                                  1.0d0))
                        color-data)))
    (register-colormap
     (make-listed-colormap colors :name name)
     :name name :force t)))

(defun initialize-colormaps ()
  "Register all built-in colormaps."
  ;; Clear existing
  (clrhash *colormaps*)

  ;; LinearSegmentedColormaps from segment data
  (%register-segment-cmap "binary" *binary-segment-data*)
  (%register-segment-cmap "gray" *gray-segment-data*)
  (%register-segment-cmap "autumn" *autumn-segment-data*)
  (%register-segment-cmap "spring" *spring-segment-data*)
  (%register-segment-cmap "summer" *summer-segment-data*)
  (%register-segment-cmap "winter" *winter-segment-data*)
  (%register-segment-cmap "cool" *cool-segment-data*)
  (%register-segment-cmap "hot" *hot-segment-data*)
  (%register-segment-cmap "jet" *jet-segment-data*)
  (%register-segment-cmap "coolwarm" *coolwarm-segment-data*)

  ;; From-list colormaps (sequential/diverging with RGB control points)
  (%register-from-list-cmap "Blues" *blues-colors*)
  (%register-from-list-cmap "Greens" *greens-colors*)
  (%register-from-list-cmap "Greys" *greys-colors*)
  (%register-from-list-cmap "Reds" *reds-colors*)
  (%register-from-list-cmap "RdBu" *rdbu-colors*)
  (%register-from-list-cmap "RdYlGn" *rdylgn-colors*)
  (%register-from-list-cmap "Spectral" *spectral-colors*)

  ;; Perceptually uniform colormaps (interpolated from control points)
  (let ((n 256))
    (%register-listed-cmap "viridis"
                           (%interpolate-control-points *viridis-control-points* n))
    (%register-listed-cmap "plasma"
                           (%interpolate-control-points *plasma-control-points* n))
    (%register-listed-cmap "inferno"
                           (%interpolate-control-points *inferno-control-points* n))
    (%register-listed-cmap "magma"
                           (%interpolate-control-points *magma-control-points* n))
    (%register-listed-cmap "cividis"
                           (%interpolate-control-points *cividis-control-points* n)))

  ;; Aliases
  (setf (gethash "grey" *colormaps*) (gethash "gray" *colormaps*))

  (format t "~&; cl-matplotlib.primitives: ~D colormaps registered.~%"
          (hash-table-count *colormaps*)))

;; Initialize at load time
(initialize-colormaps)

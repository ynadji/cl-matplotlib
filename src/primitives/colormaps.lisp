;;;; colormaps.lisp — Colormap data tables and registry
;;;; Ported from matplotlib._cm, _cm_listed, and cm
;;;;
;;;; Contains ~22 core colormaps and the colormap registry.

(in-package #:cl-matplotlib.primitives)

;;; ============================================================
;;; Colormap Registry
;;; ============================================================

(defvar *colormaps* (make-hash-table :test 'equal)
  "Global colormap registry: name (string) → colormap object.")

(defun register-colormap (cmap &key name force)
  "Register CMAP in the global colormap registry.
NAME overrides cmap's name. FORCE allows overwriting."
  (let ((cname (or name (colormap-name cmap))))
    (when (and (gethash cname *colormaps*) (not force))
      (error "A colormap named ~S is already registered" cname))
    (setf (gethash cname *colormaps*) cmap)
    cmap))

(defun get-colormap (name)
  "Look up a colormap by NAME (string or keyword).
Returns the colormap object, or signals an error if not found."
  (let ((sname (etypecase name
                 (keyword (string-downcase (symbol-name name)))
                 (string name)
                 (symbol (string-downcase (symbol-name name))))))
    (or (gethash sname *colormaps*)
        ;; Try case-insensitive lookup
        (block nil
          (maphash (lambda (k v)
                     (when (string-equal k sname)
                       (return v)))
                   *colormaps*)
          (error "Unknown colormap: ~S" name)))))

(defun list-colormaps ()
  "Return a sorted list of all registered colormap names."
  (let ((names nil))
    (maphash (lambda (k v) (declare (ignore v)) (push k names)) *colormaps*)
    (sort names #'string<)))

